# RPC URL for the Ethereum Sepolia Testnet (e.g., from Alchemy or Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Your deployer wallet's private key (do NOT include the '0x' prefix)
PRIVATE_KEY=your_private_key_here

# Etherscan API Key for automatic smart contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here
