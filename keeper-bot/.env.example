# Mock mode toggle (set to false when Role A delivers contracts)
MOCK_MODE=true

# RPC endpoint for Sepolia testnet (required for live mode)
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Private key of the keeper wallet (DO NOT COMMIT THIS FILE, required for live mode)
PRIVATE_KEY=your_private_key_here

# Contract address (required for live mode, fill in when Role A delivers)
VAULT_ADDRESS=

# Polling interval in seconds
POLL_INTERVAL=15

# Minimum health factor threshold for liquidation
LIQUIDATION_THRESHOLD=1.0
